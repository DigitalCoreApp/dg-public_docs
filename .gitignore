# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# internal docs / planning (not for public repo)
/docs/

# safety net: keep internal-style planning docs out of the root,
# even if accidentally created outside /docs/
/*-REVIEW.md
/*-PLAN.md
/*-SPECIFICATION.md
/*-INVENTORY.md
/*-BRIEF.md
/*-PROPOSAL.md
/*-AUDIT.md
/*-NOTES.md
/*-INTERNAL.md

# editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
Thumbs.db
